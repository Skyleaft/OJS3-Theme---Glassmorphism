{
  "name": "ojs-glass-theme",
  "version": "1.0.2",
  "description": "Modern glassmorphism theme for OJS 3.5",
  "private": true,
  "scripts": {
    "build": "npx @tailwindcss/cli -i ./tailwind.css -o ./styles/glass-theme.css --minify",
    "dev": "npx @tailwindcss/cli -i ./tailwind.css -o ./styles/glass-theme.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0"
  }
}
